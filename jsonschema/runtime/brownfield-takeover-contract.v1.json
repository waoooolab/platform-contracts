{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waoooolab.dev/contracts/runtime/brownfield-takeover-contract.v1.json",
  "title": "BrownfieldTakeoverContractV1",
  "description": "Brownfield takeover normalization contract for drift detection, workload profile matrix, and attach/import lifecycle.",
  "type": "object",
  "required": [
    "schema_version",
    "drift_detection",
    "workload_profile_matrix",
    "attach_import"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "brownfield_takeover_contract.v1"
    },
    "drift_detection": {
      "type": "object",
      "required": [
        "missing_configs",
        "baseline_diff",
        "remediation_backlog"
      ],
      "properties": {
        "missing_configs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "baseline_diff": {
          "type": "object",
          "required": [
            "added",
            "removed",
            "changed"
          ],
          "properties": {
            "added": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "removed": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "changed": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        },
        "remediation_backlog": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "item",
              "priority",
              "owner"
            ],
            "properties": {
              "item": {
                "type": "string",
                "minLength": 1
              },
              "priority": {
                "type": "string",
                "enum": [
                  "P0",
                  "P1",
                  "P2"
                ]
              },
              "owner": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "workload_profile_matrix": {
      "type": "object",
      "required": [
        "dev_profile",
        "visual_profile"
      ],
      "properties": {
        "dev_profile": {
          "$ref": "#/$defs/workload_profile"
        },
        "visual_profile": {
          "$ref": "#/$defs/workload_profile"
        }
      },
      "additionalProperties": false
    },
    "attach_import": {
      "type": "object",
      "required": [
        "source_registration_state",
        "identity_mapping",
        "import_lifecycle_action"
      ],
      "properties": {
        "source_registration_state": {
          "type": "string",
          "enum": [
            "registered",
            "unregistered",
            "partially_registered"
          ]
        },
        "identity_mapping": {
          "type": "object",
          "required": [
            "source_locator",
            "target_scope_key"
          ],
          "properties": {
            "source_locator": {
              "type": "string",
              "minLength": 1
            },
            "source_task_id": {
              "type": "string",
              "minLength": 1
            },
            "target_scope_key": {
              "type": "string",
              "minLength": 1
            },
            "target_run_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "import_lifecycle_action": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "scan_source",
              "normalize_baseline",
              "bind_scope_identity",
              "resume_orchestrated_control",
              "emit_takeover_audit"
            ]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "workload_profile": {
      "type": "object",
      "required": [
        "checklist",
        "acceptance_gate",
        "remediation_order"
      ],
      "properties": {
        "checklist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "acceptance_gate": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "remediation_order": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
