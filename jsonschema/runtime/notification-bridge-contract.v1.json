{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waoooolab.dev/contracts/runtime/notification-bridge-contract.v1.json",
  "title": "NotificationBridgeContractV1",
  "description": "Notification bridge dedupe/escalation policy for session blocked/recovered events.",
  "type": "object",
  "required": [
    "schema_version",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "notification_bridge.v1"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "event_type",
          "severity",
          "channels",
          "dedupe_key",
          "dedupe_window_seconds",
          "escalation_window_seconds"
        ],
        "properties": {
          "event_type": {
            "type": "string",
            "enum": [
              "session_blocked",
              "session_recovered"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "critical"
            ]
          },
          "channels": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "email",
                "im",
                "oncall"
              ]
            }
          },
          "dedupe_key": {
            "type": "string",
            "minLength": 1
          },
          "dedupe_window_seconds": {
            "type": "integer",
            "minimum": 0
          },
          "escalation_window_seconds": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
