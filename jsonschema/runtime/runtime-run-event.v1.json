{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waoooolab.dev/contracts/runtime/runtime-run-event.v1.json",
  "title": "RuntimeRunEventV1",
  "description": "Run requested/status events emitted by runtime-execution.",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "tenant_id",
    "app_id",
    "session_key",
    "trace_id",
    "correlation_id",
    "ts",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "runtime.run.requested",
        "runtime.run.status"
      ]
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "session_key": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "required": [
        "run_id",
        "status",
        "retry_attempts"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "requested",
            "queued",
            "dispatching",
            "running",
            "waiting_approval",
            "retrying",
            "succeeded",
            "failed",
            "canceled",
            "timed_out"
          ]
        },
        "retry_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "route": {
          "type": "object",
          "required": [
            "event_type",
            "execution_mode",
            "route_target"
          ],
          "properties": {
            "event_type": {
              "type": "string",
              "enum": [
                "runtime.route.decided"
              ]
            },
            "execution_mode": {
              "type": "string",
              "enum": [
                "control",
                "compute"
              ]
            },
            "route_target": {
              "type": "string",
              "enum": [
                "langgraph-core",
                "device-hub"
              ]
            },
            "placement_event_type": {
              "type": "string",
              "enum": [
                "device.lease.acquired"
              ]
            },
            "device_id": {
              "type": "string",
              "minLength": 1
            },
            "lease_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "orchestration": {
          "type": "object",
          "required": [
            "run_depth",
            "child_run_ids"
          ],
          "properties": {
            "parent_run_id": {
              "type": "string",
              "minLength": 1
            },
            "parent_task_id": {
              "type": "string",
              "minLength": 1
            },
            "run_depth": {
              "type": "integer",
              "minimum": 0
            },
            "child_run_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "canceled_by_run_id": {
              "type": "string",
              "minLength": 1
            },
            "cancellation_reason": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "runtime.run.requested"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "required": [
              "route"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
