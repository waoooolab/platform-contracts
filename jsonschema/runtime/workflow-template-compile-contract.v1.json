{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waoooolab.dev/contracts/runtime/workflow-template-compile-contract.v1.json",
  "title": "WorkflowTemplateCompileContractV1",
  "description": "Canonical template-to-workflow compile contract for Product Builder phase/step DAG assembly.",
  "type": "object",
  "required": [
    "schema_version",
    "template_id",
    "template_version",
    "template_type",
    "phase_graph",
    "compile_output",
    "deterministic_rules",
    "acceptance_criteria"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "workflow_template_compile_contract.v1"
    },
    "template_id": {
      "type": "string",
      "minLength": 1
    },
    "template_version": {
      "type": "string",
      "minLength": 1
    },
    "template_type": {
      "type": "string",
      "enum": [
        "development_pipeline",
        "visual_pipeline",
        "project_ops_pipeline"
      ]
    },
    "phase_graph": {
      "type": "object",
      "required": [
        "phases"
      ],
      "properties": {
        "phases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "phase_id",
              "steps"
            ],
            "properties": {
              "phase_id": {
                "type": "string",
                "minLength": 1
              },
              "depends_on_phase_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "uniqueItems": true
              },
              "steps": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "step_id",
                    "operation_type"
                  ],
                  "properties": {
                    "step_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "operation_type": {
                      "type": "string",
                      "enum": [
                        "tool",
                        "model",
                        "approval",
                        "notify",
                        "script"
                      ]
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "compile_output": {
      "type": "object",
      "required": [
        "workflow_kind",
        "task_id_strategy",
        "dependency_policy"
      ],
      "properties": {
        "workflow_kind": {
          "type": "string",
          "enum": [
            "coding",
            "content",
            "ops",
            "compute_pipeline",
            "integration"
          ]
        },
        "task_id_strategy": {
          "type": "string",
          "enum": [
            "phase_step_hash",
            "phase_step_sequence",
            "template_scoped_counter"
          ]
        },
        "dependency_policy": {
          "type": "string",
          "enum": [
            "strict_phase_order",
            "declared_dependencies_only",
            "hybrid"
          ]
        }
      },
      "additionalProperties": false
    },
    "deterministic_rules": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "enum": [
          "stable_task_id_generation",
          "dependency_order_deterministic",
          "phase_step_roundtrip_safe",
          "idempotent_recompile"
        ]
      },
      "uniqueItems": true
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "template_schema_valid",
          "compile_graph_valid",
          "stable_task_ids",
          "dependency_closure_valid",
          "roundtrip_projection_valid"
        ]
      },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "template_type": {
            "const": "development_pipeline"
          }
        },
        "required": [
          "template_type"
        ]
      },
      "then": {
        "properties": {
          "compile_output": {
            "properties": {
              "workflow_kind": {
                "const": "coding"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "template_type": {
            "const": "visual_pipeline"
          }
        },
        "required": [
          "template_type"
        ]
      },
      "then": {
        "properties": {
          "compile_output": {
            "properties": {
              "workflow_kind": {
                "const": "compute_pipeline"
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
