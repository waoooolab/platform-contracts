{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waoooolab.dev/contracts/runtime/execution-plan-contract.v1.json",
  "title": "ExecutionPlanContractV1",
  "description": "Canonical compiled DAG execution plan generated from workflow templates.",
  "type": "object",
  "required": [
    "plan_id",
    "objective",
    "nodes",
    "edges",
    "entry_point",
    "metadata"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "entry_point": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "phase_id",
          "step_id",
          "operation_type",
          "status",
          "depends_on_node_ids",
          "metadata"
        ],
        "properties": {
          "node_id": {
            "type": "string",
            "minLength": 1
          },
          "phase_id": {
            "type": "string",
            "minLength": 1
          },
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "operation_type": {
            "type": "string",
            "enum": [
              "tool",
              "model",
              "approval",
              "notify",
              "script"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pending"
            ]
          },
          "depends_on_node_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "metadata": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from_node_id",
          "to_node_id"
        ],
        "properties": {
          "from_node_id": {
            "type": "string",
            "minLength": 1
          },
          "to_node_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "schema_version",
        "template_source",
        "template_id",
        "template_version",
        "template_type",
        "compiled_at",
        "phase_count",
        "node_count",
        "edge_count",
        "retry_policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "execution_plan_contract.v1"
        },
        "template_source": {
          "type": "string",
          "enum": [
            "provided",
            "generated_default"
          ]
        },
        "template_id": {
          "type": "string",
          "minLength": 1
        },
        "template_version": {
          "type": "string",
          "minLength": 1
        },
        "template_type": {
          "type": "string",
          "minLength": 1
        },
        "compiled_at": {
          "type": "string",
          "format": "date-time"
        },
        "phase_count": {
          "type": "integer",
          "minimum": 1
        },
        "node_count": {
          "type": "integer",
          "minimum": 1
        },
        "edge_count": {
          "type": "integer",
          "minimum": 0
        },
        "retry_policy": {
          "type": "object",
          "required": [
            "max_attempts",
            "attempted"
          ],
          "properties": {
            "max_attempts": {
              "type": "integer",
              "minimum": 1
            },
            "attempted": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step_id",
          "action",
          "status"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
