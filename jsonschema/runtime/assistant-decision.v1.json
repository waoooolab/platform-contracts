{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waoooolab.dev/contracts/runtime/assistant-decision.v1.json",
  "title": "AssistantDecisionV1",
  "description": "Assistant-level orchestration decision boundary between direct assistant path and runtime-governed execution path.",
  "type": "object",
  "required": [
    "decision_version",
    "execution_path",
    "decision_reason_code",
    "entry_mode",
    "task_plane",
    "governance_signals",
    "scenario_profile",
    "chain_profile",
    "agent_dispatch_policy",
    "task_governance_policy",
    "layered_authority_contract",
    "path_promotion_decision_matrix"
  ],
  "properties": {
    "decision_version": {
      "type": "string",
      "const": "assistant-boundary.v1"
    },
    "execution_path": {
      "type": "string",
      "enum": [
        "assistant_direct",
        "runtime_governed"
      ],
      "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/execution_path/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
    },
    "decision_reason_code": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9_]+$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "session_key": {
      "type": "string",
      "minLength": 1
    },
    "entry_mode": {
      "type": "string",
      "enum": [
        "assistant",
        "workflow",
        "tools",
        "mixed"
      ],
      "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/entry_mode/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
    },
    "task_plane": {
      "type": "string",
      "enum": [
        "agent_work",
        "workflow_work",
        "runtime_workload"
      ],
      "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/task_plane/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
    },
    "governance_signals": {
      "type": "object",
      "required": [
        "has_dispatch_policy",
        "requires_durable_state",
        "retry_attempts"
      ],
      "properties": {
        "has_dispatch_policy": {
          "type": "boolean"
        },
        "requires_durable_state": {
          "type": "boolean"
        },
        "retry_attempts": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "scenario_profile": {
      "type": "object",
      "required": [
        "scenario_id",
        "decision_basis"
      ],
      "properties": {
        "scenario_id": {
          "type": "string",
          "enum": [
            "coding_assistant",
            "visual_generation",
            "operations"
          ],
          "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/scenario_profile/properties/scenario_id/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
        },
        "decision_basis": {
          "type": "string",
          "enum": [
            "user_entry",
            "task_plane",
            "workload_signal"
          ],
          "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/scenario_profile/properties/decision_basis/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
        }
      },
      "additionalProperties": false
    },
    "chain_profile": {
      "type": "object",
      "required": [
        "chain_id",
        "planning_mode"
      ],
      "properties": {
        "chain_id": {
          "type": "string",
          "enum": [
            "assistant_loop",
            "workflow_pipeline",
            "tool_realtime",
            "mixed_supervision"
          ],
          "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/chain_profile/properties/chain_id/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
        },
        "planning_mode": {
          "type": "string",
          "enum": [
            "iterative",
            "compiled",
            "direct",
            "hybrid"
          ],
          "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/chain_profile/properties/planning_mode/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
        }
      },
      "additionalProperties": false
    },
    "agent_dispatch_policy": {
      "type": "object",
      "required": [
        "dispatch_mode",
        "target_executor"
      ],
      "properties": {
        "dispatch_mode": {
          "type": "string",
          "enum": [
            "single_agent",
            "delegate_team",
            "tool_first",
            "hybrid"
          ],
          "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/agent_dispatch_policy/properties/dispatch_mode/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
        },
        "target_executor": {
          "type": "string",
          "enum": [
            "agent_orchestrator",
            "runtime_execution",
            "mixed"
          ],
          "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/agent_dispatch_policy/properties/target_executor/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
        },
        "preferred_providers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "task_governance_policy": {
      "type": "object",
      "required": [
        "runtime_required",
        "hitl_required",
        "approval_mode"
      ],
      "properties": {
        "runtime_required": {
          "type": "boolean"
        },
        "hitl_required": {
          "type": "boolean"
        },
        "approval_mode": {
          "type": "string",
          "enum": [
            "none",
            "required"
          ],
          "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/task_governance_policy/properties/approval_mode/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
        }
      },
      "additionalProperties": false
    },
    "harness_policy": {
      "type": "object",
      "required": [
        "requirements_requested",
        "resolution_status",
        "required_components",
        "resolved_bindings"
      ],
      "properties": {
        "requirements_requested": {
          "type": "boolean"
        },
        "resolution_status": {
          "type": "string",
          "enum": [
            "not_requested",
            "resolved",
            "invalid"
          ],
          "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/harness_policy/properties/resolution_status/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
        },
        "required_components": {
          "type": "object",
          "properties": {
            "sub_agent_id": {
              "type": "string",
              "minLength": 1
            },
            "sandbox_profile_id": {
              "type": "string",
              "minLength": 1
            },
            "memory_backend_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "resolved_bindings": {
          "type": "object",
          "properties": {
            "sub_agent_id": {
              "type": "string",
              "minLength": 1
            },
            "sub_agent_name": {
              "type": "string",
              "minLength": 1
            },
            "sub_agent_version": {
              "type": "string",
              "minLength": 1
            },
            "sub_agent_status": {
              "type": "string",
              "minLength": 1
            },
            "sandbox_profile_id": {
              "type": "string",
              "minLength": 1
            },
            "sandbox_profile_name": {
              "type": "string",
              "minLength": 1
            },
            "sandbox_profile_version": {
              "type": "string",
              "minLength": 1
            },
            "sandbox_profile_status": {
              "type": "string",
              "minLength": 1
            },
            "memory_backend_id": {
              "type": "string",
              "minLength": 1
            },
            "memory_backend_name": {
              "type": "string",
              "minLength": 1
            },
            "memory_backend_version": {
              "type": "string",
              "minLength": 1
            },
            "memory_backend_status": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "resolution_error": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "layered_authority_contract": {
      "type": "object",
      "required": [
        "schema_version",
        "upstream_decision_plane",
        "upstream_decision_role",
        "downstream_execution_governance_owner",
        "runtime_lifecycle_truth_owner",
        "peer_parallel_scheduler_allowed",
        "runtime_may_request_step_planning"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "orchestration_layered_authority.v1"
        },
        "upstream_decision_plane": {
          "type": "string",
          "enum": [
            "agent_orchestrator",
            "agent_framework",
            "external_orchestrator"
          ],
          "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/layered_authority_contract/properties/upstream_decision_plane/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
        },
        "upstream_decision_role": {
          "type": "string",
          "const": "decision_planning"
        },
        "downstream_execution_governance_owner": {
          "type": "string",
          "const": "runtime_execution"
        },
        "runtime_lifecycle_truth_owner": {
          "type": "boolean",
          "const": true
        },
        "peer_parallel_scheduler_allowed": {
          "type": "boolean",
          "const": false
        },
        "runtime_may_request_step_planning": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    },
    "path_promotion_decision_matrix": {
      "type": "object",
      "required": [
        "schema_version",
        "promotion_direction",
        "promotion_target_path",
        "deterministic_rule_order",
        "trigger_snapshot",
        "promotion_required",
        "promotion_reason_codes"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "assistant_path_promotion_matrix.v1"
        },
        "promotion_direction": {
          "type": "string",
          "const": "assistant_direct_to_runtime_governed"
        },
        "promotion_target_path": {
          "type": "string",
          "const": "runtime_governed"
        },
        "deterministic_rule_order": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "hitl_gate",
              "reliability_guard",
              "policy_gate",
              "audit_gate"
            ],
            "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/path_promotion_decision_matrix/properties/deterministic_rule_order/items/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
          }
        },
        "trigger_snapshot": {
          "type": "object",
          "required": [
            "hitl_required",
            "reliability_risk_level",
            "policy_gate_required",
            "audit_trail_required"
          ],
          "properties": {
            "hitl_required": {
              "type": "boolean"
            },
            "reliability_risk_level": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high",
                "critical"
              ],
              "$comment": "SSOT source pointer: jsonschema/runtime/assistant-decision.v1.json#/properties/path_promotion_decision_matrix/properties/trigger_snapshot/properties/reliability_risk_level/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
            },
            "policy_gate_required": {
              "type": "boolean"
            },
            "audit_trail_required": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "promotion_required": {
          "type": "boolean"
        },
        "promotion_reason_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
